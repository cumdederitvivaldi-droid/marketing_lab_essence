# 개발: apps/public/disposal-guide/.env.local (gitignored)
# 배포: GitHub Actions secrets / VM 의 /shared/.env

# Supabase (필수)
NEXT_PUBLIC_SUPABASE_URL=
# 브라우저 측에서 사용 (RLS 적용된 SELECT/INSERT)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 측 URL (NEXT_PUBLIC_SUPABASE_URL 과 동일 값, 서버 코드 fallback용)
SUPABASE_URL=
# 서버 측 익명 키 (NEXT_PUBLIC_SUPABASE_ANON_KEY 와 동일 값, 서버 코드 fallback용)
SUPABASE_ANON_KEY=
# 서버 측 API route 에서 사용 (RLS 우회, feedback insert 등)
SUPABASE_SERVICE_ROLE_KEY=
# public VM 공용 env fallback (service role)
COVERING_SUPABASE_URL=
COVERING_SUPABASE_KEY=

# Analytics (선택)
# Mixpanel browser token. 미설정 시 앱에 포함된 public token 사용.
NEXT_PUBLIC_MIXPANEL_TOKEN=

# Slack (선택)
# 결과 페이지 의견 보내기 → 채널 알림 봇 토큰
SLACK_BOT_TOKEN=
# Slack 채널 ID (기본값: C0B2TRG6DCK)
DISPOSAL_GUIDE_FEEDBACK_SLACK_CHANNEL=

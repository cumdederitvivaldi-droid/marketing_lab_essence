    {
      "id": 20,
      "title": "일별 상담 건수 (신규/기존)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "grafana-bigquery-datasource",
        "uid": "bigquery-datasource"
      },
      "targets": [
        {
          "rawSql": "SELECT TIMESTAMP(DATE(createdAt)) AS time, COUNT(*) AS total_chats, COUNTIF(tags LIKE '%고객유형/FIRST%') AS new_customers, COUNTIF(tags LIKE '%고객유형/기존%') AS existing_customers FROM `covering-app-ccd23.cx_data.channel_talk_userchat` WHERE $__timeFilter(createdAt) GROUP BY time ORDER BY time",
          "format": 1
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "barAlignment": 0,
            "fillOpacity": 80,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "total_chats"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "전체"
              },
              {
                "id": "custom.drawStyle",
                "value": "line"
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "custom.lineWidth",
                "value": 2
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "white",
                  "mode": "fixed"
                }
              },
              {
                "id": "custom.stacking",
                "value": {
                  "mode": "none"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "new_customers"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "신규고객"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "light-blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "existing_customers"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "기존고객"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "semi-dark-blue",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 21,
      "title": "일별 평균 대기시간 & 응답시간 (분)",

    },
    {
      "id": 40,
      "title": "카테고리별 상담 건수 & 대기시간",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 14,
        "h": 10
      },
      "datasource": {
        "type": "grafana-bigquery-datasource",
        "uid": "bigquery-datasource"
      },
      "targets": [
        {
          "rawSql": "SELECT CASE WHEN tags LIKE '%차량등록%' THEN '차량등록' WHEN tags LIKE '%수거품목%' THEN '수거품목 문의' WHEN tags LIKE '%배출방법%' THEN '배출방법 문의' WHEN tags LIKE '%무응종결%' THEN '무응답 종결' WHEN tags LIKE '%미수거/주소착오%' THEN '미수거-주소착오' WHEN tags LIKE '%미수거/수거지연%' THEN '미수거-수거지연' WHEN tags LIKE '%미수거/미배출%' THEN '미수거-미배출' WHEN tags LIKE '%미수거/봉투미사용%' THEN '미수거-봉투미사용' WHEN tags LIKE '%미수거/누락%' THEN '미수거-누락' WHEN tags LIKE '%지역문의%' THEN '지역 문의' WHEN tags LIKE '%구독%' THEN '구독 관련' WHEN tags LIKE '%배송%' THEN '배송 관련' WHEN tags LIKE '%주문수정%' OR tags LIKE '%취소%' THEN '주문수정/취소' WHEN tags LIKE '%확인필요%' THEN '수거 확인필요' ELSE '기타' END AS category, COUNT(*) AS count, ROUND(AVG(waitingTime) / 1000 / 60, 1) AS avg_wait_min, ROUND(AVG(avgReplyTime) / 1000 / 60, 1) AS avg_reply_min, ROUND(AVG(replyCount), 1) AS avg_replies, ROUND(AVG(TIMESTAMP_DIFF(closedAt, createdAt, MINUTE)), 1) AS avg_resolution_min FROM `covering-app-ccd23.cx_data.channel_talk_userchat` WHERE $__timeFilter(createdAt) AND tags IS NOT NULL AND tags != '' GROUP BY category ORDER BY count DESC",
          "format": 0
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "category"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "카테고리"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "count"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "건수"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "value": null,
                      "color": "transparent"
                    },
                    {
                      "value": 100,
                      "color": "rgba(50, 116, 217, 0.2)"
                    },
                    {
                      "value": 500,
                      "color": "rgba(50, 116, 217, 0.4)"
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "avg_wait_min"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "평균 대기(분)"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "value": null,
                      "color": "transparent"
                    },
                    {
                      "value": 60,
                      "color": "rgba(255, 152, 48, 0.2)"
                    },
                    {
                      "value": 150,
                      "color": "rgba(242, 73, 92, 0.3)"
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "avg_reply_min"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "평균 응답(분)"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "avg_replies"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "평균 응답횟수"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "avg_resolution_min"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "평균 해결(분)"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",

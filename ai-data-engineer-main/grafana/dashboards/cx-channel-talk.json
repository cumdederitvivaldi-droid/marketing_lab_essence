      },
      "datasource": {
        "type": "grafana-bigquery-datasource",
        "uid": "bigquery-datasource"
      },
      "targets": [
        {
          "rawSql": "SELECT TIMESTAMP(DATE(createdAt)) AS time, ROUND(AVG(waitingTime) / 1000 / 60, 1) AS avg_waiting_min, ROUND(AVG(avgReplyTime) / 1000 / 60, 1) AS avg_reply_min FROM `covering-app-ccd23.cx_data.channel_talk_userchat` WHERE $__timeFilter(createdAt) AND waitingTime IS NOT NULL GROUP BY time ORDER BY time",
          "format": 1
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "min",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "avg_waiting_min"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "평균 대기시간"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "avg_reply_min"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "평균 응답시간"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "light-green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {

    {
      "id": 30,
      "title": "시간대별 상담 건수 (KST)",
      "type": "bargauge",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 14,
        "h": 8
      },
      "datasource": {
        "type": "grafana-bigquery-datasource",
        "uid": "bigquery-datasource"
      },
      "targets": [
        {
          "rawSql": "SELECT CONCAT(LPAD(CAST(EXTRACT(HOUR FROM createdAt) AS STRING), 2, '0'), ':00') AS hour, COUNT(*) AS chat_count FROM `covering-app-ccd23.cx_data.channel_talk_userchat` WHERE $__timeFilter(createdAt) GROUP BY hour ORDER BY hour",
          "format": 0
        }
      ],
      "transformations": [
        {
          "id": "rowsToFields",
          "options": {
            "mappings": [
              { "fieldName": "hour", "type": "name" },
              { "fieldName": "chat_count", "type": "value" }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "light-blue" },
              { "value": 300, "color": "semi-dark-blue" },
              { "value": 400, "color": "dark-orange" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": true, "calcs": [] },
        "orientation": "vertical",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizWidth": 10,
        "minVizHeight": 10
      }
    },
    {
      "id": 31,
      "title": "요일별 상담 건수",
      "type": "bargauge",
      "gridPos": {
        "x": 14,
        "y": 15,
        "w": 10,
        "h": 8
      },
      "datasource": {
        "type": "grafana-bigquery-datasource",
        "uid": "bigquery-datasource"
      },
      "targets": [
        {
          "rawSql": "SELECT CASE EXTRACT(DAYOFWEEK FROM createdAt) WHEN 2 THEN '1_월' WHEN 3 THEN '2_화' WHEN 4 THEN '3_수' WHEN 5 THEN '4_목' WHEN 6 THEN '5_금' WHEN 7 THEN '6_토' WHEN 1 THEN '7_일' END AS day_of_week, COUNT(*) AS chat_count FROM `covering-app-ccd23.cx_data.channel_talk_userchat` WHERE $__timeFilter(createdAt) GROUP BY day_of_week ORDER BY day_of_week",
          "format": 0
        }
      ],
      "transformations": [
        {
          "id": "rowsToFields",
          "options": {
            "mappings": [
              { "fieldName": "day_of_week", "type": "name" },
              { "fieldName": "chat_count", "type": "value" }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "light-purple" },
              { "value": 800, "color": "semi-dark-purple" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": true, "calcs": [] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizWidth": 10,
        "minVizHeight": 15
      }
    },
    {
      "id": 4,
      "title": "문의 카테고리 분석",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 24,
        "h": 1

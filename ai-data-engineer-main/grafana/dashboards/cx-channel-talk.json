    {
      "id": 41,
      "title": "미수거 유형별 추이 (주간)",
      "type": "timeseries",
      "gridPos": {
        "x": 14,
        "y": 24,
        "w": 10,
        "h": 10
      },
      "datasource": {
        "type": "grafana-bigquery-datasource",
        "uid": "bigquery-datasource"
      },
      "targets": [
        {
          "rawSql": "SELECT TIMESTAMP(DATE_TRUNC(DATE(createdAt), WEEK(MONDAY))) AS time, COUNTIF(tags LIKE '%미수거/주소착오%') AS addr_error, COUNTIF(tags LIKE '%미수거/수거지연%') AS delayed, COUNTIF(tags LIKE '%미수거/미배출%') AS not_placed, COUNTIF(tags LIKE '%미수거/봉투미사용%') AS no_bag, COUNTIF(tags LIKE '%미수거/누락%') AS missed FROM `covering-app-ccd23.cx_data.channel_talk_userchat` WHERE $__timeFilter(createdAt) AND tags LIKE '%미수거%' GROUP BY time ORDER BY time",
          "format": 1
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "always",
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "addr_error"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "주소착오"

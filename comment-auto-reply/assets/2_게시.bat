@echo off
chcp 65001 >nul
REM ============================================================
REM  2단계: 검토 엑셀의 승인 결과 반영 → 게시(답글+하트)
REM  (검토 엑셀을 저장하고 닫은 뒤 실행하세요. 크롬도 켜져 있어야 합니다)
REM ============================================================
cd /d "%~dp0\.."

echo 승인 결과(엑셀)를 반영하는 중...
python "scripts\apply_review.py"
if errorlevel 1 ( echo [오류] 승인 반영 실패. 엑셀이 닫혀 있는지 확인하세요. & pause & exit /b 1 )

echo.
echo === 미리보기(DRY-RUN): 입력만 하고 전송하지 않습니다 ===
python "scripts\post_replies.py"

echo.
echo ============================================================
echo  위 미리보기가 정상으로 보이면, 아무 키나 눌러 실제 게시(+하트)를 시작합니다.
echo  지금 중단하려면 이 창을 그냥 닫으세요.
echo ============================================================
pause

echo 실제 게시 중... (1회 최대 10건, 사이에 지연)
python "scripts\post_replies.py" --commit --limit 10
echo.
echo 완료. 남은 건이 있으면 2_게시.bat 을 다시 실행하세요. (이미 단 댓글은 자동 제외)
pause

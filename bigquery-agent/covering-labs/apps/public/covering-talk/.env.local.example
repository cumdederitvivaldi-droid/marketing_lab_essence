# ─────────────────────────────────────────────
# covering-talk — Environment variables
# 실제 값은 1Password / VM `/shared/.env` 에서 복사해 .env.local 에 붙여 사용.
# 자세한 분류는 docs/ops/environment.md 참조.
# ─────────────────────────────────────────────

# ── 런타임 ──────────────────────────────────
NODE_ENV=

# ── 인증 ────────────────────────────────────
JWT_SECRET=                                  # JWT 서명용 (강력한 랜덤, 32자+)

# ── Supabase (자체 인스턴스 1개) ─────────────
NEXT_PUBLIC_SUPABASE_URL=                    # 브라우저 측
NEXT_PUBLIC_SUPABASE_ANON_KEY=               # 브라우저 측 익명
SUPABASE_URL=                                # 서버 측
SUPABASE_ANON_KEY=                           # 서버 측 익명
SUPABASE_SERVICE_ROLE_KEY=                   # 서버 측 service role (RLS 우회)

# ── Supabase 외부 커버링 DB (sendToCovering 단방향 동기화) ─
# 방문수거 상담사 답변 시 외부 covering DB 의 bookings 테이블에 INSERT.
# 비우면 lib/covering/client.ts:sendToCovering 호출 시 throw → 방문 send 실패.
COVERING_SUPABASE_URL=
COVERING_SUPABASE_KEY=

# ── AI ─────────────────────────────────────
ANTHROPIC_API_KEY=                           # Claude (Sonnet 메인 응답 + Haiku 톤·분류·커바니)
OPENAI_API_KEY=                              # ChatGPT (응급용 — app_settings.ai_provider="openai" 시 활성)
VOYAGE_AI_API_KEY=                           # 임베딩 (voyage-2 한국어, 채널톡 RAG)

# ── 해피톡 (방문수거) ───────────────────────
HAPPYTALK_API_HOST=
HT_CLIENT_ID=                                # 방문수거 채널 클라이언트 (런치와 동일 자격증명)
HT_CLIENT_SECRET=
SENDER_KEY=                                  # 방문수거 카카오 채널 sender key

# ── 해피톡 (런치) ───────────────────────────
LUNCH_HAPPYTALK_API_HOST=
LUNCH_HT_CLIENT_ID=                          # = HT_CLIENT_ID 와 동일 값
LUNCH_HT_CLIENT_SECRET=                      # = HT_CLIENT_SECRET 와 동일
LUNCH_SENDER_KEY=                            # 런치 전용 채널 sender key (방문과 다름, 2026-04-17 운영 전환)

# ── 채널톡 ──────────────────────────────────
CHANNELTALK_APP_ID=                          # Native Functions
CHANNELTALK_APP_SECRET=
CHANNELTALK_ACCESS_KEY=                      # Open API
CHANNELTALK_ACCESS_SECRET=
CHANNELTALK_DESK_COOKIE=                     # Desk API (메시지 삭제) — 30일 로테이션 필수

# ── 카카오 ──────────────────────────────────
KAKAO_REST_API_KEY=                          # 주소 정규화 (방문 + 런치 + 채널톡 공유)
NEXT_PUBLIC_KAKAO_MAP_KEY=                   # Kakao Map JS SDK (대시보드 지역 지도 — 클라이언트 노출)

# ── 결제 (NicePay) — 방문 + 런치 공유 ───────
NICEPAY_MID=
NICEPAY_MERCHANT_KEY=
NICEPAY_USR_ID=

# ── Google Sheets / OAuth ───────────────────
GOOGLE_CLIENT_ID=                            # OAuth 로그인
GOOGLE_CLIENT_SECRET=
GOOGLE_SERVICE_ACCOUNT_EMAIL=                # Sheets API service account
GOOGLE_PRIVATE_KEY=                          # multiline 가능
GOOGLE_SHEET_ID=                             # 단건_수거 + 단건_정산 시트 (방문 + 런치 공유)
GOOGLE_SHEET_GID=                            # 특정 탭 GID (선택)

# ── Bolta (전자세금계산서 · 런치 전용) ──────
BOLTA_API_KEY=
BOLTA_CUSTOMER_KEY=                          # Bolta 측 고객 키 (우리 = 공급자)
BOLTA_SUPPLIER_BIZ_NUMBER=
BOLTA_SUPPLIER_NAME=
BOLTA_SUPPLIER_REP_NAME=
BOLTA_SUPPLIER_EMAIL=

# ── Dhero 배송 (방문 전용) ──────────────────
DHERO_API_URL=
DHERO_TOKEN=
DHERO_SPOT_CODE=
DHERO_DEV_API_URL=                           # dev 환경용
DHERO_DEV_TOKEN=

# ── Slack (방문 익일 브리핑) ────────────────
SLACK_BOT_TOKEN=                             # xoxb-... 봇 토큰
SLACK_PICKUP_CHANNEL_ID=                     # 미설정 시 fallback C0AENH7JW2Y

# ── 스윗트래커 비즈메시지 (실험실 — 김원빈/강성진만 사용) ─
SWEETTRACKER_PROFILE_KEY=
SWEETTRACKER_USERID=

# ── /api/cron/* 외부 호출 인증 (covering-labs public 노출 보호) ─
CRON_SECRET=                                 # 외부 cron runner 의 x-cron-secret 헤더와 일치해야 통과
